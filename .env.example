# ===========================================
# 核心配置
# ===========================================

# 应用配置
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ===========================================
# 数据库配置
# ===========================================

# MySQL 数据库
DATABASE_URL="mysql://nexus:nexus_password@localhost:3306/nexus_prime"

# Redis 缓存
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# ===========================================
# 向量数据库配置
# ===========================================

# Milvus
MILVUS_ADDRESS="localhost:19530"
MILVUS_TOKEN=""
VECTOR_DIMENSION=1536

# ===========================================
# AI 服务配置
# ===========================================

# DashScope (阿里云灵积)
DASHSCOPE_API_KEY="your_dashscope_api_key"
DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
DASHSCOPE_MODEL="qwen-plus-latest"
EMBEDDING_MODEL="text-embedding-v3"

# ===========================================
# 认证配置
# ===========================================

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# ===========================================
# LantuConnect 配置
# ===========================================

# LantuConnect-Backend 服务地址
LANTU_CONNECT_URL="http://localhost:8080"
LANTU_CONNECT_API_KEY=""

# ===========================================
# 可选配置
# ===========================================

# 日志级别
LOG_LEVEL="debug"

# ReAct 配置
REACT_MAX_ITERATIONS=10
