generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid()) @db.VarChar(36)
  username      String   @unique @db.VarChar(50)
  passwordHash  String   @map("password_hash") @db.VarChar(255)
  email         String?  @unique @db.VarChar(100)
  displayName   String?  @map("display_name") @db.VarChar(100)
  avatarUrl     String?  @map("avatar_url") @db.VarChar(500)
  role          Role     @default(USER)
  status        Status   @default(ACTIVE)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  lastLoginAt   DateTime? @map("last_login_at")
  settings      Json?    @default("{}")

  conversations    Conversation[]
  userSettings      UserSettings?
  apiKeys           UserApiKey[]
  auditLogs         AuditLog[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

enum Status {
  ACTIVE
  INACTIVE
  BANNED
}

model Conversation {
  id            String   @id @default(uuid()) @db.VarChar(36)
  userId        String   @map("user_id") @db.VarChar(36)
  title         String?  @db.VarChar(255)
  summary       String?
  messageCount  Int      @default(0) @map("message_count")
  totalTokens   Int      @default(0) @map("total_tokens")
  lastMessageAt DateTime? @map("last_message_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  metadata      Json?    @default("{}")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
  @@index([lastMessageAt])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid()) @db.VarChar(36)
  conversationId String   @map("conversation_id") @db.VarChar(36)
  role           MessageRole
  // 长对话/长回复须用 LONGTEXT，避免超过 VARCHAR/TEXT 上限导致保存失败
  content        String   @db.LongText
  toolCalls      Json?    @map("tool_calls")
  toolResults    Json?    @map("tool_results")
  thinkingLog              Json?    @map("thinking_log")
  thinkingStepDurationsMs  Json?    @map("thinking_step_durations_ms")
  tokensUsed     Int      @default(0) @map("tokens_used")
  latencyMs      Int      @default(0) @map("latency_ms")
  model          String?  @db.VarChar(100)
  createdAt      DateTime @default(now()) @map("created_at")

  conversation     Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  toolInvocations  ToolInvocation[]

  @@index([conversationId])
  @@index([createdAt])
  @@map("messages")
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model ToolInvocation {
  id           String          @id @default(uuid()) @db.VarChar(36)
  messageId    String          @map("message_id") @db.VarChar(36)
  toolName     String          @map("tool_name") @db.VarChar(100)
  resourceType String?         @map("resource_type") @db.VarChar(50)
  resourceId   String?         @map("resource_id") @db.VarChar(50)
  arguments    Json?           @default("{}")
  result       Json?
  status       ToolStatus      @default(PENDING)
  errorMessage String?         @map("error_message")
  latencyMs    Int             @default(0) @map("latency_ms")
  cached       Boolean         @default(false)
  createdAt    DateTime        @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([toolName])
  @@map("tool_invocations")
}

enum ToolStatus {
  PENDING
  SUCCESS
  ERROR
}

model UserSettings {
  id                    String   @id @default(uuid()) @db.VarChar(36)
  userId                String   @unique @map("user_id") @db.VarChar(36)
  defaultModel          String   @default("qwen-plus-latest") @map("default_model") @db.VarChar(100)
  systemPrompt          String?  @map("system_prompt")
  theme                 Theme    @default(SYSTEM)
  language              String   @default("zh-CN") @db.VarChar(10)
  maxTokens             Int      @default(4096) @map("max_tokens")
  temperature           Float    @default(0.7)
  enableHistoryContext  Boolean  @default(true) @map("enable_history_context")
  historyContextLimit   Int      @default(10) @map("history_context_limit")
  enableVectorSearch    Boolean  @default(true) @map("enable_vector_search")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

enum Theme {
  LIGHT
  DARK
  SYSTEM
}

model UserApiKey {
  id          String   @id @default(uuid()) @db.VarChar(36)
  userId      String   @map("user_id") @db.VarChar(36)
  name        String   @db.VarChar(100)
  keyHash     String   @map("key_hash") @db.VarChar(255)
  keyPrefix   String   @map("key_prefix") @db.VarChar(20)
  provider    String   @default("lantuconnect") @db.VarChar(50)
  isDefault   Boolean  @default(false) @map("is_default")
  lastUsedAt  DateTime? @map("last_used_at")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_api_keys")
}

model CacheEntry {
  id             String     @id @default(uuid()) @db.VarChar(36)
  cacheType      CacheType  @map("cache_type")
  cacheKey       String     @unique @map("cache_key") @db.VarChar(255)
  userId         String?    @map("user_id") @db.VarChar(36)
  conversationId String?    @map("conversation_id") @db.VarChar(36)
  hitCount       Int        @default(0) @map("hit_count")
  lastHitAt      DateTime?  @map("last_hit_at")
  expiresAt      DateTime   @map("expires_at")
  createdAt      DateTime   @default(now()) @map("created_at")

  @@index([cacheKey])
  @@index([expiresAt])
  @@map("cache_entries")
}

enum CacheType {
  LLM_RESPONSE
  TOOL_RESULT
  SESSION
}

model AuditLog {
  id           String   @id @default(uuid()) @db.VarChar(36)
  userId       String?  @map("user_id") @db.VarChar(36)
  action       String   @db.VarChar(100)
  resourceType String?  @map("resource_type") @db.VarChar(50)
  resourceId   String?  @map("resource_id") @db.VarChar(100)
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  userAgent    String?  @map("user_agent")
  details      Json?    @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
